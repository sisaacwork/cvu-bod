# ─────────────────────────────────────────────────────────────────────────────
# CVU BoD Title Finder — Streamlit Secrets
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file: cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# 2. Fill in the values below with your real credentials.
# 3. NEVER commit secrets.toml to Git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

[mysql]
host     = "your-db-host"       # e.g. "db.example.com" or "127.0.0.1"
port     = 3306                  # default MySQL port; change if needed
user     = "your-readonly-user"
password = "your-password"
database = "your-database-name"

